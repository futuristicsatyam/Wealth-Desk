# ---- Database (PostgreSQL / Neon) ----
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@direct-host/db?sslmode=require"

# ---- Auth ----
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_SECRET_PREVIOUS=""
APP_URL="http://localhost:3000"

# ---- PII encryption (KYC fields: PAN/Aadhaar) ----
# Optional: dedicated key for encrypting KYC at rest. Falls back to AUTH_SECRET
# when unset. Set this (and keep it stable) before storing real KYC data.
PII_ENCRYPTION_KEY=""

# ---- Razorpay ----
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="xxxxxxxx"

# ---- OTP hashing secret ----
# Dedicated secret used to hash email & phone OTPs (falls back to AUTH_SECRET).
PHONE_OTP_SECRET=""

# ---- Phone OTP / Twilio ----
# Used ONLY for phone verification at paid checkout (low volume). Dev falls back
# to a console code when unset. (Registration uses EMAIL OTP via Resend, below.)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ---- Telegram (optional) ----
# Bot token from @BotFather. Required for BOTH the broadcast channel and the
# per-member DM trade alerts (the "Telegram alerts" plan perk).
TELEGRAM_BOT_TOKEN=""
# Channel/group id for admin broadcasts (unrelated to per-member DM alerts).
TELEGRAM_CHANNEL_ID=""
# Bot @username (without the @) — used to build the members' one-tap connect
# link (t.me/<username>?start=<token>). Required for per-member DM alerts.
TELEGRAM_BOT_USERNAME=""
# Secret you set when registering the webhook; Telegram echoes it in the
# X-Telegram-Bot-Api-Secret-Token header so we can reject spoofed calls.
# Register the webhook once with:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=<APP_URL>/api/telegram/webhook&secret_token=<SECRET>"
TELEGRAM_WEBHOOK_SECRET=""

# ---- Email / Resend (email OTP + transactional mail) ----
# Preferred email provider. When set, used for the registration email OTP and
# all transactional email. Requires a verified sending domain on Resend.
RESEND_API_KEY=""
# Verified from-address, e.g. "Wealth Research Desk <noreply@yourdomain.com>".
RESEND_FROM=""

# ---- SMTP email (fallback if Resend not set; dev falls back to console) ----
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="research@wealthdesk.in"

# ---- Cron (outbox dispatcher) ----
# Secret that protects /api/cron/dispatch. Set this in Vercel and Vercel Cron
# will automatically send it as an "Authorization: Bearer <CRON_SECRET>" header.
# Generate with: openssl rand -hex 24
CRON_SECRET=""

# ---- Business / compliance ----
# APP_NAME="Wealth Research Desk"
# SEBI_REGISTRATION="INH000000000"
# GSTIN="27AAAAA0000A1Z5"
# SUPPORT_EMAIL="support@wealthdesk.in"
